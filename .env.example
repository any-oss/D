# Application Settings
APP_NAME=Skills-RAG-System
APP_ENV=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security - CHANGE THESE IN PRODUCTION!
API_KEY=your-secure-api-key-min-16-characters
JWT_SECRET=your-super-secure-jwt-secret-min-32-characters-here
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_MINUTES=60

# Database Configuration
DATABASE_URL=postgresql://skills_user:your-db-password@localhost:5432/skills_rag
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# RAG & Model Settings
MODEL_PATH=./models
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_CONTEXT_LENGTH=4096

# Resource Monitoring Thresholds
MEMORY_THRESHOLD_PERCENT=85.0
DISK_THRESHOLD_PERCENT=90.0
CPU_THRESHOLD_PERCENT=90.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/app/logs/app.log

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
