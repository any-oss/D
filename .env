# Team B AI-Agent System - Environment Configuration
# Copy this file to .env and update with your values

# API Security
TEAM_B_API_KEY=your-secure-api-key-here
TEAM_B_JWT_SECRET=your-super-secret-jwt-key-here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/team_b_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=team_b_user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=team_b_db

# Model Configuration
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=tinyllama

# System Configuration
LOG_LEVEL=INFO
MAX_RAM_USAGE_PERCENT=85
SAFE_RAM_USAGE_PERCENT=70

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_METRICS=true
