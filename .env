# Development Environment Configuration
APP_NAME=Skills-RAG-System
APP_ENV=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Security - Development keys (CHANGE IN PRODUCTION!)
API_KEY=dev-api-key-change-in-production-12345
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_MINUTES=60

# Database Configuration
DATABASE_URL=postgresql://skills_user:devpassword@localhost:5432/skills_rag
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# RAG & Model Settings
MODEL_PATH=./models
LLAMA_MODEL=Qwen2.5-0.5b-instruct-q4_k_m.gguf
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_CONTEXT_LENGTH=4096
LLAMA_SERVER_HOST=localhost
LLAMA_SERVER_PORT=8080

# Resource Monitoring Thresholds
MEMORY_THRESHOLD_PERCENT=85.0
DISK_THRESHOLD_PERCENT=90.0
CPU_THRESHOLD_PERCENT=90.0

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
